      "exercises": [
        {
          "type": "choice",
          "q": "Что больше: 3/4 или 2/3?",
          "options": ["3/4", "2/3", "Они равны"],
          "answer": "3/4",
          "hints": [
            "Приведите к общему знаменателю 12.",
            "3/4 = 9/12, 2/3 = 8/12."
          ]
        },
        {
          "type": "input",
          "q": "Сократите дробь 6/8 (запишите в виде a/b).",
          "answer": "3/4",
          "hints": [
            "Разделите числитель и знаменатель на 2.",
            "6 ÷ 2 = 3, 8 ÷ 2 = 4."
          ]
        },
        {
          "type": "choice",
          "q": "Какая дробь равна 1/2?",
          "options": ["2/4", "3/5", "4/9", "5/11"],
          "answer": "2/4",
          "hints": [
            "Умножьте числитель и знаменатель 1/2 на одно и то же число.",
            "1 × 2 = 2, 2 × 2 = 4."
          ]
        },
        {
          "type": "input",
          "q": "Сократите дробь 9/12 (запишите в виде a/b).",
          "answer": "3/4",
          "hints": [
            "Найдите НОД чисел 9 и 12.",
            "НОД(9, 12) = 3; 9 ÷ 3 = 3, 12 ÷ 3 = 4."
          ]
        },
        {
          "type": "choice",
          "q": "Что меньше: 1/4 или 1/3?",
          "options": ["1/4", "1/3", "Они равны"],
          "answer": "1/4",
          "hints": [
            "Чем больше знаменатель при одинаковом числителе, тем меньше дробь.",
            "1/4 = 3/12, 1/3 = 4/12."
          ]
        }
      ]
    },
